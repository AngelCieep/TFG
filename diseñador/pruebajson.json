{
  "header": {
    "projectName": "mi-web-prueba",
    "template": "template1",
    "version": "1.0",
    "grid": 12
  },

  "body": {
    "id": "page-root",
    "component": "Page",
    "bootstrap": {
      "colStart": 1,
      "colSpan": 12
    },
    "props": {},

    "children": [
      {
        "id": "header-1",
        "component": "Header1",
        "bootstrap": {
          "colStart": 1,
          "colSpan": 12
        },
        "props": {
          "brand": "Mi Web",
          "links": [
            { "label": "Inicio", "href": "/" },
            { "label": "Sobre nosotros", "href": "/about" },
            { "label": "Contacto", "href": "/contact" }
          ]
        },
        "children": []
      },

      {
        "id": "section-1",
        "component": "Section",
        "bootstrap": {
          "colStart": 1,
          "colSpan": 12
        },
        "props": {
          "background": "light"
        },

        "children": [
          {
            "id": "container-1",
            "component": "Container",
            "bootstrap": {
              "colStart": 1,
              "colSpan": 12
            },
            "props": {},

            "children": [
              {
                "id": "text-1",
                "component": "Text",
                "bootstrap": {
                  "colStart": 1,
                  "colSpan": 8
                },
                "props": {
                  "text": "Bienvenido a mi web generada automáticamente"
                },
                "children": []
              },

              {
                "id": "button-1",
                "component": "Button",
                "bootstrap": {
                  "colStart": 5,
                  "colSpan": 2
                },
                "props": {
                  "label": "Saber más",
                  "color": "primary"
                },
                "children": []
              }
            ]
          }
        ]
      },

      {
        "id": "footer-1",
        "component": "Footer1",
        "bootstrap": {
          "colStart": 1,
          "colSpan": 12
        },
        "props": {
          "copyright": "© 2026 Mi Web. Todos los derechos reservados.",
          "links": [
            { "label": "Privacidad", "href": "/privacy" },
            { "label": "Términos", "href": "/terms" }
          ]
        },
        "children": []
      }
    ]
  }
}
